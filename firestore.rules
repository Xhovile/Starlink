rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for bookings collection
    match /bookings/{bookingId} {
      // Users can read/write their own bookings.
      // Admins (identified by email or admin role check) can read and write all bookings.
      allow read, write: if request.auth != null && (
        resource == null || 
        resource.data.userId == request.auth.uid || 
        request.resource.data.userId == request.auth.uid ||
        request.auth.token.email == 'xhovilepublications@gmail.com' ||
        request.auth.token.email.matches('.*admin.*')
      );
    }
  }
}
