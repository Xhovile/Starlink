rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if user document exists safely
    function userDocExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper to get user document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user is platform admin safely
    function isPlatformAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && (
          request.auth.token.email == 'xhovilepublications@gmail.com' ||
          request.auth.token.email.matches('.*admin.*')
        )) || (
          userDocExists() && getUserData().role == 'platform_admin'
        )
      );
    }

    // Check if user is operator admin for a specific operator safely
    function isOperatorAdmin(operatorId) {
      return isSignedIn() && userDocExists() && (
        getUserData().role == 'operator_admin' && getUserData().operatorId == operatorId
      );
    }

    // Operators rules
    match /operators/{operatorId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || isOperatorAdmin(operatorId);
    }

    // Users rules - with recursion prevention
    match /users/{userId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == userId || 
        (request.auth.uid != userId && isPlatformAdmin())
      );
    }

    // Routes rules
    match /routes/{routeId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || (isSignedIn() && isOperatorAdmin(request.resource.data.operatorId));
    }

    // Trips rules
    match /trips/{tripId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || (isSignedIn() && isOperatorAdmin(request.resource.data.operatorId));
    }

    // Bookings rules
    match /bookings/{bookingId} {
      allow read: if true; // Public verified searches and ticket downloaders
      allow write: if true; // Anyone can book (public checkout/walk-in) or admin/operator can write
    }

    // Tickets rules
    match /tickets/{ticketId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || (isSignedIn() && isOperatorAdmin(request.resource.data.operatorId));
    }

    // Vehicles rules
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || (isSignedIn() && isOperatorAdmin(request.resource.data.operatorId));
    }

    // SeatLayouts rules
    match /seatLayouts/{layoutId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || (isSignedIn() && isOperatorAdmin(request.resource.data.operatorId));
    }

    // Payments rules
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        isPlatformAdmin() || 
        isOperatorAdmin(resource.data.operatorId)
      );
      allow write: if true; // allow creation during booking
    }

    // AuditLogs rules
    match /auditLogs/{logId} {
      allow read: if isPlatformAdmin() || (isSignedIn() && isOperatorAdmin(resource.data.operatorId));
      allow write: if true; // allow writing of logs
    }
  }
}
